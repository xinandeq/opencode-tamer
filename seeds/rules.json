{
  "version": "0.1.0",
  "rules": [
    {
      "id": "seed_001",
      "name": "Confirm before editing files",
      "trigger": { "tool": ["write", "edit", "multiedit", "MultiEdit", "str_replace_editor", "str_replace", "string_replace", "write_file"], "condition": "cross_file_or_delete" },
      "instruction": "Before modifying or deleting files, tell the user which files and changes are planned, then wait for explicit confirmation.",
      "intercept_level": "L2",
      "status": "disabled",
      "hit_count": 0,
      "pass_count": 0,
      "false_positive_count": 0,
      "created_at": "2026-07-14T00:00:00Z",
      "last_hit_at": null,
      "salience": 0.9,
      "source": "seed"
    },
    {
      "id": "seed_002",
      "name": "Block destructive commands",
      "trigger": { "tool": ["bash", "run_terminal_cmd", "terminal", "shell"], "condition": "dangerous_command" },
      "instruction": "Block destructive commands such as rm -rf, git reset --hard, drop table, and dd if=. These commands can irreversibly delete data.",
      "intercept_level": "L1",
      "status": "active",
      "hit_count": 0,
      "pass_count": 0,
      "false_positive_count": 0,
      "created_at": "2026-07-14T00:00:00Z",
      "last_hit_at": null,
      "salience": 1.0,
      "source": "seed"
    },
    {
      "id": "seed_003",
      "name": "Do not guess APIs or paths",
      "trigger": { "tool": ["*"], "condition": "uncertainty_signal" },
      "instruction": "When an API name, file path, or function name is uncertain, search the code or ask the user instead of guessing.",
      "intercept_level": "L3",
      "status": "disabled",
      "hit_count": 0,
      "pass_count": 0,
      "false_positive_count": 0,
      "created_at": "2026-07-14T00:00:00Z",
      "last_hit_at": null,
      "salience": 0.7,
      "source": "seed"
    },
    {
      "id": "seed_004",
      "name": "Read before editing",
      "trigger": { "tool": ["write", "edit", "multiedit", "MultiEdit", "str_replace_editor", "str_replace", "string_replace", "write_file"], "condition": "unread_file" },
      "instruction": "Read a file before editing it so existing behavior and important content are not overwritten.",
      "intercept_level": "L2",
      "status": "disabled",
      "hit_count": 0,
      "pass_count": 0,
      "false_positive_count": 0,
      "created_at": "2026-07-14T00:00:00Z",
      "last_hit_at": null,
      "salience": 0.8,
      "source": "seed"
    },
    {
      "id": "seed_005",
      "name": "Avoid sudo",
      "trigger": { "tool": ["bash", "run_terminal_cmd", "terminal", "shell"], "condition": "sudo" },
      "instruction": "Do not use sudo. If elevated privileges are genuinely required, explain why and request confirmation first.",
      "intercept_level": "L1",
      "status": "disabled",
      "hit_count": 0,
      "pass_count": 0,
      "false_positive_count": 0,
      "created_at": "2026-07-14T00:00:00Z",
      "last_hit_at": null,
      "salience": 0.6,
      "source": "seed"
    },
    {
      "id": "seed_006",
      "name": "Verify after changes",
      "trigger": { "tool": ["*"], "condition": "always" },
      "instruction": "Before declaring a change complete, run the relevant checks or inspect the result instead of stopping after code edits.",
