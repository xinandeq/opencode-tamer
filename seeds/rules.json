{
  "version": "0.1.0",
  "rules": [
    {
      "id": "seed_001",
      "name": "改文件先确认",
      "trigger": { "tool": ["write", "edit", "multiedit", "MultiEdit", "str_replace_editor", "str_replace", "string_replace", "write_file"], "condition": "cross_file_or_delete" },
      "instruction": "修改或删除文件前，必须先告诉用户要改什么文件、改什么内容，等待用户明确确认后才执行。",
      "intercept_level": "L2",
      "status": "disabled",
      "hit_count": 0,
      "pass_count": 0,
      "false_positive_count": 0,
      "created_at": "2026-07-14T00:00:00Z",
      "last_hit_at": null,
      "salience": 0.9,
      "source": "seed"
    },
    {
      "id": "seed_002",
      "name": "破坏性命令阻断",
      "trigger": { "tool": ["bash", "run_terminal_cmd", "terminal", "shell"], "condition": "dangerous_command" },
      "instruction": "执行 rm -rf / git reset --hard / drop table / dd if= 等破坏性命令前必须确认。这些命令会不可逆地删除数据。",
      "intercept_level": "L1",
      "status": "active",
      "hit_count": 0,
      "pass_count": 0,
      "false_positive_count": 0,
      "created_at": "2026-07-14T00:00:00Z",
      "last_hit_at": null,
      "salience": 1.0,
      "source": "seed"
    },
    {
      "id": "seed_003",
      "name": "不猜API路径",
      "trigger": { "tool": ["*"], "condition": "uncertainty_signal" },
      "instruction": "当你不确定 API 名称、文件路径或函数名时，不要猜测。先搜索代码或询问用户确认。",
      "intercept_level": "L3",
      "status": "disabled",
      "hit_count": 0,
      "pass_count": 0,
      "false_positive_count": 0,
      "created_at": "2026-07-14T00:00:00Z",
      "last_hit_at": null,
      "salience": 0.7,
      "source": "seed"
    },
    {
      "id": "seed_004",
      "name": "先读后改",
      "trigger": { "tool": ["write", "edit", "multiedit", "MultiEdit", "str_replace_editor", "str_replace", "string_replace", "write_file"], "condition": "unread_file" },
      "instruction": "修改你还没读过的文件前，先读取文件了解现有内容，避免覆盖重要内容。",
      "intercept_level": "L2",
      "status": "disabled",
      "hit_count": 0,
      "pass_count": 0,
      "false_positive_count": 0,
      "created_at": "2026-07-14T00:00:00Z",
      "last_hit_at": null,
      "salience": 0.8,
      "source": "seed"
    },
    {
      "id": "seed_005",
      "name": "不用sudo",
      "trigger": { "tool": ["bash", "run_terminal_cmd", "terminal", "shell"], "condition": "sudo" },
      "instruction": "不要使用 sudo 命令。如果确实需要提权，先告诉用户原因并请求确认。",
      "intercept_level": "L1",
      "status": "disabled",
      "hit_count": 0,
      "pass_count": 0,
      "false_positive_count": 0,
      "created_at": "2026-07-14T00:00:00Z",
      "last_hit_at": null,
      "salience": 0.6,
      "source": "seed"
    },
    {
      "id": "seed_006",
      "name": "改动后验证",
      "trigger": { "tool": ["*"], "condition": "always" },
      "instruction": "声称完成修改后，运行验证脚本或检查修改结果，不要只写代码不验证。",
      "intercept_level": "L3",
      "status": "disabled",
      "hit_count": 0,
      "pass_count": 0,
      "false_positive_count": 0,
      "created_at": "2026-07-14T00:00:00Z",
      "last_hit_at": null,
      "salience": 0.5,
      "source": "seed"
    }
  ]
}
